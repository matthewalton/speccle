{
  "name": "speccle",
  "version": "0.12.0",
  "description": "Speccle's deterministic tooling: spec lint and the oracle-strength heatmap. Never calls an LLM.",
  "license": "MIT",
  "author": {
    "name": "Matt Alton",
    "email": "mattalton97@gmail.com"
  },
  "homepage": "https://github.com/matthewalton/speccle/tree/main/packages/oracle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthewalton/speccle.git",
    "directory": "packages/oracle"
  },
  "bugs": "https://github.com/matthewalton/speccle/issues",
  "keywords": [
    "spec",
    "testing",
    "mutation-testing",
    "vertical-slices",
    "oracle-strength"
  ],
  "type": "module",
  "bin": {
    "speccle": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/bundle-skills.mjs",
    "prepublishOnly": "pnpm build && pnpm test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-istanbul": "^4.1.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
